// MARK: - Ajuda Conteúdo
"help.tips" = "Dicas Pro";
"help.gettingStarted.content" = "Este app usa o scanner LiDAR do seu dispositivo para criar modelos 3D precisos de ambientes.\n\nRequisitos para Digitalizar:\n• iPhone 12 Pro ou posterior\n• iPad Pro (2020 ou posterior)\n• iOS 16.0 ou posterior\n\nNota: Você pode visualizar ambientes salvos em qualquer dispositivo, mesmo sem LiDAR! Use iCloud para sincronizar ambientes entre dispositivos.";
"help.icloudSetup.content" = "Ative a sincronização iCloud para acessar seus ambientes salvos em todos os seus dispositivos - mesmo aqueles sem LiDAR!\n\nComo Ativar:\n1. Vá para Configurações (ícone de engrenagem)\n2. Ative \"Sincronização iCloud\"\n3. Seus ambientes serão sincronizados automaticamente\n\nRequisitos:\n• Conectado ao iCloud nas Configurações do iOS\n• iCloud Drive ativado\n• Conexão com a Internet\n\nBenefícios:\n• Acesse digitalizações de dispositivos sem LiDAR\n• Backup automático de suas digitalizações\n• Compartilhe ambientes entre iPhone e iPad\n• Visualize modelos 3D em qualquer lugar";
"help.scanning.content" = "1. Toque em \"Iniciar Nova Digitalização\" na tela inicial\n2. Aponte seu dispositivo para um canto do ambiente\n3. Mova-se lentamente ao longo de cada parede, mantendo a parede à vista\n4. Digitalize todas as paredes, janelas, portas e aberturas\n5. Inclua móveis e objetos que deseja capturar\n6. Observe a pré-visualização inferior para ver seu progresso\n7. Toque em \"Concluído\" quando o ambiente estiver completo\n\nDicas para Melhores Resultados:\n• Mantenha seu dispositivo na vertical\n• Mova-se lenta e constantemente\n• Garanta boa iluminação\n• Digitalize cada parede pelo menos uma vez\n• Aproxime-se dos detalhes que deseja capturar";
"help.exporting.content" = "Após completar uma digitalização, você pode exportá-la em múltiplos formatos:\n\nFormatos de Modelo 3D:\n• USDZ - Melhor para dispositivos Apple, AR Quick Look\n• OBJ - Formato 3D universal para software de modelagem\n• STL - Para aplicações de impressão 3D\n\nFormatos de Planta Baixa:\n• PNG - Imagem para compartilhamento rápido\n• SVG - Formato vetorial para design gráfico\n• DXF - Formato CAD para arquitetos/designers\n\nPara exportar:\n1. Complete sua digitalização ou abra um ambiente salvo\n2. Toque no botão exportar\n3. Escolha seu formato\n4. Compartilhe via AirDrop, email ou salve em Arquivos\n\nTodas as medidas estão incluídas nos arquivos exportados.";
"help.feature.3d.title" = "Captura 3D de Ambiente";
"help.feature.3d.description" = "Crie modelos 3D precisos com tecnologia LiDAR. O app detecta automaticamente paredes, janelas, portas e móveis.";
"help.feature.wifi.title" = "Mapa de Calor WiFi";
"help.feature.wifi.description" = "Ative o rastreamento WiFi durante a digitalização para criar um mapa de calor de intensidade de sinal. Perfeito para planejar a localização do roteador. Requer permissão de localização.";
"help.feature.photo.title" = "Captura de Fotos";
"help.feature.photo.description" = "Tire fotos durante a digitalização para documentar o espaço. As fotos são salvas com sua digitalização e exibidas na planta baixa.";
"help.feature.export.title" = "Múltiplos Formatos de Exportação";
"help.feature.export.description" = "Exporte suas digitalizações em vários formatos:\n• USDZ - Modelo 3D para AR/Visualização\n• OBJ - Modelo 3D para software CAD\n• STL - Modelo 3D para impressão 3D\n• DXF - Planta para CAD\n• SVG - Planta vetorial\n• PNG - Imagem da planta";
"help.feature.icloud.title" = "Sincronização iCloud (Opcional)";
"help.feature.icloud.description" = "Ative nas Configurações para sincronizar suas digitalizações em todos os seus dispositivos. Quando ativado, as digitalizações são armazenadas no iCloud Drive e disponíveis em todos os dispositivos conectados com seu ID Apple.";
"help.tip.lighting.title" = "Iluminação é Fundamental";
"help.tip.lighting.description" = "Digitalize em boas condições de iluminação. Luz natural do dia ou iluminação interna brilhante funciona melhor. Evite áreas muito escuras ou muito claras.";
"help.tip.slow.title" = "Devagar e Sempre";
"help.tip.slow.description" = "Mova-se lenta e suavemente. Movimentos rápidos ou tremores podem afetar a qualidade da digitalização. Tome seu tempo para melhores resultados.";
"help.tip.retry.title" = "Digitalize Múltiplas Vezes";
"help.tip.retry.description" = "Se não estiver satisfeito com a primeira digitalização, tente novamente! Cada ambiente é diferente e às vezes leva algumas tentativas para obter um resultado perfeito.";
"help.tip.save.title" = "Salve Tudo";
"help.tip.save.description" = "Ative o salvamento automático nas Configurações para nunca perder uma digitalização. Você sempre pode deletar digitalizações indesejadas mais tarde.";
"help.tip.measure.title" = "Verifique as Medidas";
"help.tip.measure.description" = "Após digitalizar, toque para ver a planta baixa e verifique se as medidas parecem corretas. O app mostra dimensões em metros ou pés.";
"help.trouble.notStarting.title" = "Digitalização Não Inicia";
"help.trouble.notStarting.description" = "Certifique-se de ter um dispositivo compatível com LiDAR (iPhone 12 Pro ou posterior, iPad Pro 2020+). Verifique se as permissões de câmera foram concedidas em Configurações → Privacidade → Câmera.";
"help.trouble.poorQuality.title" = "Qualidade de Digitalização Ruim";
"help.trouble.poorQuality.description" = "Tente estas soluções:\n• Melhore a iluminação do ambiente\n• Mova-se mais devagar\n• Aproxime-se mais das paredes e objetos\n• Digitalize cada parede múltiplas vezes\n• Limpe obstruções da lente da câmera";
"help.trouble.disappeared.title" = "Digitalizações Desaparecidas";
"help.trouble.disappeared.description" = "Se as digitalizações estiverem faltando após atualizar o app:\n• Verifique Configurações → Sincronização iCloud\n• As digitalizações agora são armazenadas em Suporte de Aplicativo\n• Digitalizações antigas podem estar na pasta Documentos";
"help.trouble.wifi.title" = "Mapa de Calor WiFi Não Funciona";
"help.trouble.wifi.description" = "O rastreamento WiFi requer:\n• Permissão de localização (Configurações → Privacidade → Localização)\n• WiFi ativado no dispositivo\n• Conectado a uma rede WiFi\n• Ativado na tela de digitalização ou em Configurações";


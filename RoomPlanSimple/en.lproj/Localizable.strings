// MARK: - Help Content
"help.tips" = "Pro Tips";
"help.gettingStarted.content" = "This app uses your device's LiDAR scanner to create accurate 3D models of rooms.\n\nRequirements for Scanning:\n• iPhone 12 Pro or later\n• iPad Pro (2020 or later)\n• iOS 16.0 or later\n\nNote: You can view saved rooms on any device, even without LiDAR! Use iCloud to sync rooms across devices.";
"help.icloudSetup.content" = "Enable iCloud sync to access your saved rooms on all your devices - even those without LiDAR!\n\nHow to Enable:\n1. Go to Settings (gear icon)\n2. Toggle \"iCloud Sync\" ON\n3. Your rooms will automatically sync\n\nRequirements:\n• Signed in to iCloud in iOS Settings\n• iCloud Drive enabled\n• Internet connection\n\nBenefits:\n• Access scans from non-LiDAR devices\n• Automatic backup of your scans\n• Share rooms across iPhone and iPad\n• View 3D models anywhere";
"help.scanning.content" = "1. Tap \"Start New Scan\" on the home screen\n2. Point your device at a corner of the room\n3. Slowly move along each wall, keeping the wall in view\n4. Scan all walls, windows, doors, and openings\n5. Include furniture and objects you want to capture\n6. Watch the bottom preview to see your progress\n7. Tap \"Done\" when the room looks complete\n\nTips for Best Results:\n• Keep your device upright\n• Move slowly and steadily\n• Ensure good lighting\n• Scan each wall at least once\n• Get close to details you want captured";
"help.exporting.content" = "After completing a scan, you can export it in multiple formats:\n\n3D Model Formats:\n• USDZ - Best for Apple devices, AR Quick Look\n• OBJ - Universal 3D format for modeling software\n• STL - For 3D printing applications\n\nFloor Plan Formats:\n• PNG - Image for quick sharing\n• SVG - Vector format for graphic design\n• DXF - CAD format for architects/designers\n\nTo export:\n1. Complete your scan or open a saved room\n2. Tap the export button\n3. Choose your format\n4. Share via AirDrop, email, or save to Files\n\nAll measurements are included in the exported files.";

// Help Features
"help.feature.3d.title" = "3D Room Capture";
"help.feature.3d.description" = "Create accurate 3D models with LiDAR technology. The app automatically detects walls, windows, doors, and furniture.";
"help.feature.wifi.title" = "WiFi Heatmap";
"help.feature.wifi.description" = "Enable WiFi tracking during scanning to create a signal strength heatmap. Perfect for planning router placement. Requires location permission.";
"help.feature.photo.title" = "Photo Capture";
"help.feature.photo.description" = "Take photos during scanning to document the space. Photos are saved with your scan and shown on the floor plan.";
"help.feature.export.title" = "Multiple Export Formats";
"help.feature.export.description" = "Export your scans in various formats:\n• USDZ - 3D model for AR/Preview\n• OBJ - 3D model for CAD software\n• STL - 3D model for 3D printing\n• DXF - Floor plan for CAD\n• SVG - Floor plan vector\n• PNG - Floor plan image";
"help.feature.icloud.title" = "iCloud Sync (Optional)";
"help.feature.icloud.description" = "Enable in Settings to sync your scans across all your devices. When enabled, scans are stored in iCloud Drive and available on all devices signed in with your Apple ID.";

// Help Tips
"help.tip.lighting.title" = "Lighting is Key";
"help.tip.lighting.description" = "Scan in good lighting conditions. Natural daylight or bright indoor lighting works best. Avoid very dark or very bright areas.";
"help.tip.slow.title" = "Slow and Steady";
"help.tip.slow.description" = "Move slowly and smoothly. Rapid movements or shaking can affect scan quality. Take your time for best results.";
"help.tip.retry.title" = "Scan Multiple Times";
"help.tip.retry.description" = "If you're not happy with the first scan, try again! Each room is different and sometimes it takes a few attempts to get it perfect.";
"help.tip.save.title" = "Save Everything";
"help.tip.save.description" = "Enable auto-save in Settings so you never lose a scan. You can always delete unwanted scans later.";
"help.tip.measure.title" = "Check Measurements";
"help.tip.measure.description" = "After scanning, tap to view floor plan and verify measurements look correct. The app shows dimensions in meters or feet.";

// Help Troubleshooting
"help.trouble.notStarting.title" = "Scan Not Starting";
"help.trouble.notStarting.description" = "Ensure you have a LiDAR-enabled device (iPhone 12 Pro or later, iPad Pro 2020+). Check that camera permissions are granted in Settings → Privacy → Camera.";
"help.trouble.poorQuality.title" = "Poor Scan Quality";
"help.trouble.poorQuality.description" = "Try these fixes:\n• Improve room lighting\n• Move more slowly\n• Get closer to walls and objects\n• Scan each wall multiple times\n• Clear obstructions from camera lens";
"help.trouble.disappeared.title" = "Scans Disappeared";
"help.trouble.disappeared.description" = "If scans are missing after updating the app:\n• Check Settings → iCloud Sync\n• Scans are now stored in Application Support\n• Old scans may be in Documents folder";
"help.trouble.wifi.title" = "WiFi Heatmap Not Working";
"help.trouble.wifi.description" = "WiFi tracking requires:\n• Location permission (Settings → Privacy → Location)\n• WiFi enabled on device\n• Connected to a WiFi network\n• Toggle ON in scan screen or Settings";


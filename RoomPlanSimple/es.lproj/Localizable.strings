// MARK: - Ayuda Contenido
"help.tips" = "Consejos Pro";
"help.gettingStarted.content" = "Esta aplicación usa el escáner LiDAR de tu dispositivo para crear modelos 3D precisos de habitaciones.\n\nRequisitos para Escanear:\n• iPhone 12 Pro o posterior\n• iPad Pro (2020 o posterior)\n• iOS 16.0 o posterior\n\nNota: ¡Puedes ver habitaciones guardadas en cualquier dispositivo, incluso sin LiDAR! Usa iCloud para sincronizar habitaciones entre dispositivos.";
"help.icloudSetup.content" = "Activa la sincronización iCloud para acceder a tus habitaciones guardadas en todos tus dispositivos, ¡incluso aquellos sin LiDAR!\n\nCómo activar:\n1. Ve a Configuración (icono de engranaje)\n2. Activa \"Sincronización iCloud\"\n3. Tus habitaciones se sincronizarán automáticamente\n\nRequisitos:\n• Conectado a iCloud en Configuración de iOS\n• iCloud Drive activado\n• Conexión a Internet\n\nBeneficios:\n• Accede a escaneos desde dispositivos sin LiDAR\n• Copia de seguridad automática de tus escaneos\n• Comparte habitaciones entre iPhone e iPad\n• Ve modelos 3D en cualquier lugar";
"help.scanning.content" = "1. Toca \"Iniciar Nuevo Escaneo\" en la pantalla principal\n2. Apunta tu dispositivo a una esquina de la habitación\n3. Muévete lentamente a lo largo de cada pared, manteniendo la pared a la vista\n4. Escanea todas las paredes, ventanas, puertas y aberturas\n5. Incluye muebles y objetos que desees capturar\n6. Observa la vista previa inferior para ver tu progreso\n7. Toca \"Listo\" cuando la habitación se vea completa\n\nConsejos para mejores resultados:\n• Mantén tu dispositivo en posición vertical\n• Muévete lenta y constantemente\n• Asegura buena iluminación\n• Escanea cada pared al menos una vez\n• Acércate a los detalles que desees capturar";
"help.exporting.content" = "Después de completar un escaneo, puedes exportarlo en múltiples formatos:\n\nFormatos de Modelo 3D:\n• USDZ - Mejor para dispositivos Apple, AR Quick Look\n• OBJ - Formato 3D universal para software de modelado\n• STL - Para aplicaciones de impresión 3D\n\nFormatos de Plano de Planta:\n• PNG - Imagen para compartir rápido\n• SVG - Formato vectorial para diseño gráfico\n• DXF - Formato CAD para arquitectos/diseñadores\n\nPara exportar:\n1. Completa tu escaneo o abre una habitación guardada\n2. Toca el botón exportar\n3. Elige tu formato\n4. Comparte via AirDrop, email o guarda en Archivos\n\nTodas las medidas están incluidas en los archivos exportados.";
"help.feature.3d.title" = "Captura 3D de Habitación";
"help.feature.3d.description" = "Crea modelos 3D precisos con tecnología LiDAR. La aplicación detecta automáticamente paredes, ventanas, puertas y muebles.";
"help.feature.wifi.title" = "Mapa de Calor WiFi";
"help.feature.wifi.description" = "Activa el rastreo WiFi durante el escaneo para crear un mapa de calor de intensidad de señal. Perfecto para planificar la ubicación del router. Requiere permiso de ubicación.";
"help.feature.photo.title" = "Captura de Fotos";
"help.feature.photo.description" = "Toma fotos durante el escaneo para documentar el espacio. Las fotos se guardan con tu escaneo y se muestran en el plano de planta.";
"help.feature.export.title" = "Múltiples Formatos de Exportación";
"help.feature.export.description" = "Exporta tus escaneos en varios formatos:\n• USDZ - Modelo 3D para AR/Vista Previa\n• OBJ - Modelo 3D para software CAD\n• STL - Modelo 3D para impresión 3D\n• DXF - Plano para CAD\n• SVG - Plano vectorial\n• PNG - Imagen del plano";
"help.feature.icloud.title" = "Sincronización iCloud (Opcional)";
"help.feature.icloud.description" = "Activa en Configuración para sincronizar tus escaneos en todos tus dispositivos. Cuando está activado, los escaneos se almacenan en iCloud Drive y están disponibles en todos los dispositivos conectados con tu ID de Apple.";
"help.tip.lighting.title" = "La Iluminación es Clave";
"help.tip.lighting.description" = "Escanea en buenas condiciones de iluminación. La luz natural del día o iluminación interior brillante funciona mejor. Evita áreas muy oscuras o muy brillantes.";
"help.tip.slow.title" = "Lento y Constante";
"help.tip.slow.description" = "Muévete lenta y suavemente. Los movimientos rápidos o temblores pueden afectar la calidad del escaneo. Tómate tu tiempo para mejores resultados.";
"help.tip.retry.title" = "Escanea Múltiples Veces";
"help.tip.retry.description" = "Si no estás contento con el primer escaneo, ¡inténtalo de nuevo! Cada habitación es diferente y a veces toma varios intentos obtener un resultado perfecto.";
"help.tip.save.title" = "Guarda Todo";
"help.tip.save.description" = "Activa el guardado automático en Configuración para nunca perder un escaneo. Siempre puedes eliminar escaneos no deseados más tarde.";
"help.tip.measure.title" = "Verifica las Medidas";
"help.tip.measure.description" = "Después de escanear, toca para ver el plano de planta y verifica que las medidas se vean correctas. La aplicación muestra dimensiones en metros o pies.";
"help.trouble.notStarting.title" = "El Escaneo No Inicia";
"help.trouble.notStarting.description" = "Asegúrate de tener un dispositivo compatible con LiDAR (iPhone 12 Pro o posterior, iPad Pro 2020+). Verifica que los permisos de cámara estén otorgados en Configuración → Privacidad → Cámara.";
"help.trouble.poorQuality.title" = "Calidad de Escaneo Pobre";
"help.trouble.poorQuality.description" = "Prueba estas soluciones:\n• Mejora la iluminación de la habitación\n• Muévete más lentamente\n• Acércate más a las paredes y objetos\n• Escanea cada pared múltiples veces\n• Limpia obstrucciones del lente de la cámara";
"help.trouble.disappeared.title" = "Escaneos Desaparecidos";
"help.trouble.disappeared.description" = "Si faltan escaneos después de actualizar la aplicación:\n• Verifica Configuración → Sincronización iCloud\n• Los escaneos ahora se almacenan en Soporte de Aplicaciones\n• Los escaneos antiguos pueden estar en la carpeta Documentos";
"help.trouble.wifi.title" = "Mapa de Calor WiFi No Funciona";
"help.trouble.wifi.description" = "El rastreo WiFi requiere:\n• Permiso de ubicación (Configuración → Privacidad → Ubicación)\n• WiFi activado en el dispositivo\n• Conectado a una red WiFi\n• Activado en la pantalla de escaneo o en Configuración";


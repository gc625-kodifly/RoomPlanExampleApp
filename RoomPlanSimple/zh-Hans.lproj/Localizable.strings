// MARK: - 帮助内容
"help.tips" = "专业提示";
"help.gettingStarted.content" = "此应用使用您设备的LiDAR扫描仪创建精确的房间3D模型。\n\n扫描要求：\n• iPhone 12 Pro或更新机型\n• iPad Pro (2020或更新)\n• iOS 16.0或更高版本\n\n注意：您可以在任何设备上查看已保存的房间，即使没有LiDAR！使用iCloud在设备间同步房间。";
"help.icloudSetup.content" = "启用iCloud同步以在所有设备上访问已保存的房间 - 即使是没有LiDAR的设备！\n\n如何启用：\n1. 前往设置（齿轮图标）\n2. 打开\"iCloud同步\"\n3. 您的房间将自动同步\n\n要求：\n• 在iOS设置中登录iCloud\n• 启用iCloud Drive\n• 互联网连接\n\n好处：\n• 从非LiDAR设备访问扫描\n• 自动备份您的扫描\n• 在iPhone和iPad间共享房间\n• 随处查看3D模型";
"help.scanning.content" = "1. 在主屏幕点击\"开始新扫描\"\n2. 将设备对准房间的一个角落\n3. 沿着每面墙缓慢移动，保持墙面在视野内\n4. 扫描所有墙壁、窗户、门和开口\n5. 包括您想要捕捉的家具和物体\n6. 观看底部预览以查看进度\n7. 当房间看起来完整时点击\"完成\"\n\n获得最佳效果的提示：\n• 保持设备垂直\n• 缓慢稳定地移动\n• 确保良好照明\n• 每面墙至少扫描一次\n• 靠近您想捕捉的细节";
"help.exporting.content" = "完成扫描后，您可以以多种格式导出：\n\n3D模型格式：\n• USDZ - 最适合Apple设备，AR快速查看\n• OBJ - 建模软件的通用3D格式\n• STL - 用于3D打印应用\n\n平面图格式：\n• PNG - 快速分享的图像\n• SVG - 图形设计的矢量格式\n• DXF - 建筑师/设计师的CAD格式\n\n导出步骤：\n1. 完成扫描或打开已保存的房间\n2. 点击导出按钮\n3. 选择格式\n4. 通过AirDrop、电子邮件分享或保存到文件\n\n所有测量数据都包含在导出文件中。";
"help.feature.3d.title" = "3D房间捕捉";
"help.feature.3d.description" = "使用LiDAR技术创建精确的3D模型。应用会自动检测墙壁、窗户、门和家具。";
"help.feature.wifi.title" = "WiFi热图";
"help.feature.wifi.description" = "扫描时启用WiFi追踪以创建信号强度热图。非常适合规划路由器位置。需要位置权限。";
"help.feature.photo.title" = "照片捕捉";
"help.feature.photo.description" = "扫描时拍照以记录空间。照片与扫描一起保存并显示在平面图上。";
"help.feature.export.title" = "多种导出格式";
"help.feature.export.description" = "以多种格式导出扫描：\n• USDZ - AR/预览的3D模型\n• OBJ - CAD软件的3D模型\n• STL - 3D打印的3D模型\n• DXF - CAD平面图\n• SVG - 矢量平面图\n• PNG - 平面图图像";
"help.feature.icloud.title" = "iCloud同步（可选）";
"help.feature.icloud.description" = "在设置中启用以在所有设备上同步扫描。启用后，扫描存储在iCloud Drive中，并在使用您的Apple ID登录的所有设备上可用。";
"help.tip.lighting.title" = "照明是关键";
"help.tip.lighting.description" = "在良好的照明条件下扫描。自然日光或明亮的室内照明效果最好。避免非常暗或非常亮的区域。";
"help.tip.slow.title" = "缓慢稳定";
"help.tip.slow.description" = "缓慢平稳地移动。快速移动或晃动会影响扫描质量。花时间获得最佳效果。";
"help.tip.retry.title" = "多次扫描";
"help.tip.retry.description" = "如果对第一次扫描不满意，请再试一次！每个房间都不同，有时需要几次尝试才能获得完美效果。";
"help.tip.save.title" = "保存所有内容";
"help.tip.save.description" = "在设置中启用自动保存，这样您永远不会丢失扫描。您始终可以稍后删除不需要的扫描。";
"help.tip.measure.title" = "检查测量";
"help.tip.measure.description" = "扫描后，点击查看平面图并验证测量看起来是否正确。应用以米或英尺显示尺寸。";
"help.trouble.notStarting.title" = "扫描无法启动";
"help.trouble.notStarting.description" = "确保您拥有支持LiDAR的设备（iPhone 12 Pro或更新，iPad Pro 2020+）。检查在设置→隐私→相机中是否已授予相机权限。";
"help.trouble.poorQuality.title" = "扫描质量差";
"help.trouble.poorQuality.description" = "尝试这些修复：\n• 改善房间照明\n• 移动更慢\n• 靠近墙壁和物体\n• 多次扫描每面墙\n• 清除相机镜头上的障碍物";
"help.trouble.disappeared.title" = "扫描消失";
"help.trouble.disappeared.description" = "如果更新应用后扫描丢失：\n• 检查设置→iCloud同步\n• 扫描现在存储在Application Support中\n• 旧扫描可能在Documents文件夹中";

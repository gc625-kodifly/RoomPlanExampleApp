// MARK: - Aide Contenu
"help.tips" = "Conseils Pro";
"help.gettingStarted.content" = "Cette application utilise le scanner LiDAR de votre appareil pour créer des modèles 3D précis de pièces.\n\nPrérequis pour le scan :\n• iPhone 12 Pro ou ultérieur\n• iPad Pro (2020 ou ultérieur)\n• iOS 16.0 ou ultérieur\n\nRemarque : Vous pouvez afficher les pièces enregistrées sur n'importe quel appareil, même sans LiDAR ! Utilisez iCloud pour synchroniser les pièces sur tous vos appareils.";
"help.icloudSetup.content" = "Activez la synchronisation iCloud pour accéder à vos pièces enregistrées sur tous vos appareils - même ceux sans LiDAR !\n\nComment activer :\n1. Allez dans Réglages (icône engrenage)\n2. Activez \"Synchronisation iCloud\"\n3. Vos pièces se synchroniseront automatiquement\n\nPrérequis :\n• Connecté à iCloud dans les Réglages iOS\n• iCloud Drive activé\n• Connexion Internet\n\nAvantages :\n• Accès aux scans depuis des appareils sans LiDAR\n• Sauvegarde automatique de vos scans\n• Partage de pièces entre iPhone et iPad\n• Visualisation des modèles 3D partout";
"help.scanning.content" = "1. Appuyez sur \"Démarrer un Nouveau Scan\" sur l'écran d'accueil\n2. Pointez votre appareil vers un coin de la pièce\n3. Déplacez-vous lentement le long de chaque mur en gardant le mur en vue\n4. Scannez tous les murs, fenêtres, portes et ouvertures\n5. Incluez les meubles et objets que vous souhaitez capturer\n6. Regardez l'aperçu en bas pour voir votre progression\n7. Appuyez sur \"Terminé\" lorsque la pièce semble complète\n\nConseils pour de meilleurs résultats :\n• Gardez votre appareil vertical\n• Déplacez-vous lentement et régulièrement\n• Assurez un bon éclairage\n• Scannez chaque mur au moins une fois\n• Approchez-vous des détails que vous voulez capturer";
"help.exporting.content" = "Après avoir terminé un scan, vous pouvez l'exporter dans plusieurs formats :\n\nFormats de modèles 3D :\n• USDZ - Optimal pour les appareils Apple, AR Quick Look\n• OBJ - Format 3D universel pour logiciels de modélisation\n• STL - Pour applications d'impression 3D\n\nFormats de plan d'étage :\n• PNG - Image pour partage rapide\n• SVG - Format vectoriel pour conception graphique\n• DXF - Format CAO pour architectes/designers\n\nPour exporter :\n1. Terminez votre scan ou ouvrez une pièce enregistrée\n2. Appuyez sur le bouton exporter\n3. Choisissez votre format\n4. Partagez via AirDrop, email ou enregistrez dans Fichiers\n\nToutes les mesures sont incluses dans les fichiers exportés.";
"help.feature.3d.title" = "Capture 3D de Pièce";
"help.feature.3d.description" = "Créez des modèles 3D précis avec la technologie LiDAR. L'application détecte automatiquement les murs, fenêtres, portes et meubles.";
"help.feature.wifi.title" = "Carte de Chaleur WiFi";
"help.feature.wifi.description" = "Activez le suivi WiFi pendant le scan pour créer une carte de chaleur de l'intensité du signal. Parfait pour planifier l'emplacement du routeur. Nécessite l'autorisation de localisation.";
"help.feature.photo.title" = "Capture de Photos";
"help.feature.photo.description" = "Prenez des photos pendant le scan pour documenter l'espace. Les photos sont enregistrées avec votre scan et affichées sur le plan d'étage.";
"help.feature.export.title" = "Formats d'Export Multiples";
"help.feature.export.description" = "Exportez vos scans dans divers formats :\n• USDZ - Modèle 3D pour AR/Aperçu\n• OBJ - Modèle 3D pour logiciel CAO\n• STL - Modèle 3D pour impression 3D\n• DXF - Plan pour CAO\n• SVG - Plan vectoriel\n• PNG - Image du plan";
"help.feature.icloud.title" = "Synchronisation iCloud (Optionnel)";
"help.feature.icloud.description" = "Activez dans Réglages pour synchroniser vos scans sur tous vos appareils. Lorsqu'activé, les scans sont stockés dans iCloud Drive et disponibles sur tous les appareils connectés avec votre identifiant Apple.";
"help.tip.lighting.title" = "L'Éclairage est Clé";
"help.tip.lighting.description" = "Scannez dans de bonnes conditions d'éclairage. La lumière naturelle du jour ou un éclairage intérieur lumineux fonctionne mieux. Évitez les zones très sombres ou très lumineuses.";
"help.tip.slow.title" = "Lent et Régulier";
"help.tip.slow.description" = "Déplacez-vous lentement et en douceur. Les mouvements rapides ou tremblements peuvent affecter la qualité du scan. Prenez votre temps pour de meilleurs résultats.";
"help.tip.retry.title" = "Scanner Plusieurs Fois";
"help.tip.retry.description" = "Si vous n'êtes pas satisfait du premier scan, réessayez ! Chaque pièce est différente et parfois il faut quelques tentatives pour obtenir un résultat parfait.";
"help.tip.save.title" = "Tout Sauvegarder";
"help.tip.save.description" = "Activez la sauvegarde automatique dans Réglages pour ne jamais perdre un scan. Vous pouvez toujours supprimer les scans indésirables plus tard.";
"help.tip.measure.title" = "Vérifier les Mesures";
"help.tip.measure.description" = "Après le scan, appuyez pour voir le plan d'étage et vérifiez que les mesures semblent correctes. L'application affiche les dimensions en mètres ou pieds.";
"help.trouble.notStarting.title" = "Scan Ne Démarre Pas";
"help.trouble.notStarting.description" = "Assurez-vous d'avoir un appareil compatible LiDAR (iPhone 12 Pro ou ultérieur, iPad Pro 2020+). Vérifiez que les autorisations caméra sont accordées dans Réglages → Confidentialité → Appareil photo.";
"help.trouble.poorQuality.title" = "Qualité de Scan Médiocre";
"help.trouble.poorQuality.description" = "Essayez ces solutions :\n• Améliorez l'éclairage de la pièce\n• Déplacez-vous plus lentement\n• Approchez-vous des murs et objets\n• Scannez chaque mur plusieurs fois\n• Nettoyez les obstructions de l'objectif de la caméra";
"help.trouble.disappeared.title" = "Scans Disparus";
"help.trouble.disappeared.description" = "Si les scans manquent après la mise à jour de l'application :\n• Vérifiez Réglages → Synchronisation iCloud\n• Les scans sont maintenant stockés dans Application Support\n• Les anciens scans peuvent être dans le dossier Documents";
"help.trouble.wifi.title" = "Carte Chaleur WiFi Ne Fonctionne Pas";
"help.trouble.wifi.description" = "Le suivi WiFi nécessite :\n• Autorisation de localisation (Réglages → Confidentialité → Localisation)\n• WiFi activé sur l'appareil\n• Connecté à un réseau WiFi\n• Activé sur l'écran de scan ou dans Réglages";

